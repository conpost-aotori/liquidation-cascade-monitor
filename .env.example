# Copy to `.env` and fill in. Loaded automatically by liqmap.distribute.
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# X (Twitter) API v2 — needs a paid plan with read+write. From developer.x.com.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
